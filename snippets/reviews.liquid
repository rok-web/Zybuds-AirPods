{%- assign review_count = section.settings.review_count | default: '214' -%}

<div class="section2 reveal">
  <div class="sec2-eyebrow">Customer Reviews</div>
  <div class="sec2-title">{{ settings.city | default: 'Hyderabad' }} <em>Speaks</em></div>
  <p class="sec2-sub">Real orders. Real deliveries. Real people across our city.</p>

  <div class="reviews2-header">
    <div class="big-score">
      <div class="big-score-num">4.9</div>
      <div class="big-score-stars">★★★★★</div>
      <div class="big-score-lbl">{{ review_count }} verified reviews</div>
    </div>
    <div class="rbars2">
      <div class="rb2row"><span class="rb2lbl">5★</span>
        <div class="rb2track"><div class="rb2fill" style="width:88%"></div></div><span class="rb2count">188</span>
      </div>
      <div class="rb2row"><span class="rb2lbl">4★</span>
        <div class="rb2track"><div class="rb2fill" style="width:9%"></div></div><span class="rb2count">19</span>
      </div>
      <div class="rb2row"><span class="rb2lbl">3★</span>
        <div class="rb2track"><div class="rb2fill" style="width:2%"></div></div><span class="rb2count">5</span>
      </div>
      <div class="rb2row"><span class="rb2lbl">2★</span>
        <div class="rb2track"><div class="rb2fill" style="width:1%"></div></div><span class="rb2count">2</span>
      </div>
      <div class="rb2row"><span class="rb2lbl">1★</span>
        <div class="rb2track"><div class="rb2fill" style="width:0%"></div></div><span class="rb2count">0</span>
      </div>
    </div>
  </div>

  <div class="reviews2-slider-wrap">
    <div class="reviews2-grid slider-track" id="reviewSlider">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="rev2" {{ block.shopify_attributes }}>
            <div class="rev2-top">
              <div class="rev2-av" style="background:{{ block.settings.avatar_color }};">
                {{ block.settings.reviewer_name | slice: 0 }}
              </div>
              <div>
                <div class="rev2-name">{{ block.settings.reviewer_name }}</div>
                <div class="rev2-loc">📍 {{ block.settings.reviewer_location }}</div>
              </div>
            </div>
            <div class="rev2-stars">★★★★★</div>
            <div class="rev2-text">{{ block.settings.review_text }}</div>
            <div class="rev2-verified">✓ {{ 'products.product.verified_purchase' | t }}</div>
            <div class="rev2-date">{{ block.settings.review_date }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Static reviews + New requested reviews {%- endcomment -%}
      {%- capture static_reviews -%}
        <!-- NEW REVIEWS -->
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#c8410a,#e85d1a);">T</div>
            <div><div class="rev2-name">Tarun Singh</div><div class="rev2-loc">📍 Kompally, {{ settings.city | default: 'Hyderabad' }}</div></div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">The bass is phenomenal! I listen to EDM and these earbuds handle it perfectly. No distortion even at max volume. Open box delivery is brilliant — I tested for 5 minutes before paying. 10/10 service!</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">2 months ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#1565c0,#42a5f5);">A</div>
            <div><div class="rev2-name">Akash Verma</div><div class="rev2-loc">📍 Uppal, {{ settings.city | default: 'Hyderabad' }}</div></div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">I travel a lot for work. These are my daily drivers now — comfortable for hours, great sound isolation on flights. 1 year warranty means I don't worry about anything. Best purchase of 2025!</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">2 months ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#1a7a3c,#4caf50);">N</div>
            <div><div class="rev2-name">Naveen Kumar</div><div class="rev2-loc">📍 Manikonda, {{ settings.city | default: 'Hyderabad' }}</div></div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">Sound quality: 10/10. Battery: 10/10. Delivery speed: 10/10. Customer service: 10/10. Mahesh runs a very professional operation. The ₹99 system is smart — keeps fake orders out. Fully recommend!</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">2 months ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#6a1b9a,#ab47bc);">S</div>
            <div><div class="rev2-name">Swathi Rao</div><div class="rev2-loc">📍 Nampally, {{ settings.city | default: 'Hyderabad' }}</div></div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">Initially hesitant about COD gadgets but GadgetHub changed my mind. Delivery person was polite, waited patiently while I tested. Product is excellent quality. Knowing it's from Telangana Street makes it feel trustworthy. Love it!</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">2 months ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#e53935,#ef9a9a);">N</div>
            <div><div class="rev2-name">Neha Sharma</div><div class="rev2-loc">📍 Banjara Hills, {{ settings.city | default: 'Hyderabad' }}</div></div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">Ordered for my husband's birthday. Delivery person waited while I checked — battery was full, pairing was instant. The 1 year warranty makes this purchase completely risk-free. Very impressed!</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">2 months ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#00838f,#4dd0e1);">H</div>
            <div><div class="rev2-name">Harish Chandra</div><div class="rev2-loc">📍 Nacharam, {{ settings.city | default: 'Hyderabad' }}</div></div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">I work night shifts, battery life is crucial for me. These last my full 8-hour shift easily. Pairing with iPhone is instant — no lag at all. Mahesh's customer service is outstanding. Will buy again!</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">2 months ago</div>
        </div>
      {%- endcapture -%}
      {{ static_reviews }}
    </div>

    <div class="reviews2-controls">
      <button class="rev2-arrow prev" onclick="scrollReviews(-1)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div class="rev2-page-indicator" id="revIndicator">1 / 4</div>
      <button class="rev2-arrow next" onclick="scrollReviews(1)">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  function scrollReviews(dir) {
    const track = document.getElementById('reviewSlider');
    const indicator = document.getElementById('revIndicator');
    const cardWidth = track.querySelector('.rev2').offsetWidth + 14; // width + gap
    const currentScroll = track.scrollLeft;
    const targetScroll = currentScroll + (cardWidth * dir);
    
    track.scrollTo({
      left: targetScroll,
      behavior: 'smooth'
    });
  }

  // Update indicator on scroll
  document.getElementById('reviewSlider').addEventListener('scroll', function() {
    const track = this;
    const cardWidth = track.querySelector('.rev2').offsetWidth + 14;
    const total = track.querySelectorAll('.rev2').length;
    const visibleCards = Math.round(track.offsetWidth / cardWidth);
    const totalPages = Math.ceil(total / visibleCards);
    const currentPage = Math.round(track.scrollLeft / track.offsetWidth) + 1;
    
    document.getElementById('revIndicator').innerText = `${currentPage} / ${totalPages}`;
  });
</script>
