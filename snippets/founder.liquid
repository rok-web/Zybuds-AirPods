<!-- ============================================================
   snippets/founder.liquid
   Founder message section
   ============================================================ -->

{%- assign founder_name = settings.founder_name | default: 'Mahesh' -%}
{%- assign founder_initial = founder_name | slice: 0 -%}
{%- assign founder_location = settings.founder_location | default: 'Suman Housing Colony, Secunderabad' -%}
{%- assign city = settings.city | default: 'Hyderabad' -%}
{%- assign city_area = settings.city_area | default: 'Secunderabad' -%}
{%- assign brand = settings.shop_name_override | default: shop.name | default: 'Zybuds' -%}
{%- assign advance = settings.advance_amount | default: '99' -%}

<div style="max-width:1440px;margin:0 auto;padding:0 5%;">
  <div class="founder2 reveal">
    <div class="founder2-av">
      {%- if section.settings.founder_image -%}
        <img src="{{ section.settings.founder_image | image_url: width: 150 }}" alt="{{ founder_name }}" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;">
      {%- else -%}
        {{ founder_initial }}
      {%- endif -%}
    </div>
    <div class="founder2-content">
      <div class="founder2-eyebrow">👤 A Message From Our Founder</div>
      <div class="founder2-title">Hi, I'm <strong>{{ founder_name }}</strong>.<br>I run <strong>{{ brand }}</strong> from {{ city_area }}.</div>
      <div class="founder2-text">
        <p>I started {{ brand }} with one simple goal — to give people in {{ city }} high-quality gadgets without overpaying online and without the risk of scams.</p>
        <p>Every product we sell is personally tested by our team before dispatch. We introduced <strong>open box delivery</strong> so you can check everything before paying — no surprises, no stress.</p>
        <p>We also provide a <strong>{{ settings.warranty_years | default: '1' }}-year warranty</strong> because we stand behind what we sell.</p>
        <p>If you ever need help, you can message me directly on WhatsApp — no bots, no waiting. I’ll personally make sure you're satisfied.</p>
      </div>
      <div class="founder2-meta">
        <div class="f2-chip">📍 <strong>Location:</strong> {{ founder_location }}</div>
        <div class="f2-chip">🏙️ <strong>City:</strong> {{ city }}, Telangana</div>
        <div class="f2-chip">📞 <strong>Phone:</strong> 9704252065</div>
        <div class="f2-chip">🛡️ <strong>Warranty:</strong> {{ settings.warranty_years | default: '1' }} Year on All Products</div>
      </div>
    </div>
  </div>
</div>
