<!-- NAVBAR -->
<nav>
  <a href="{{ routes.root_url }}" class="logo" style="text-decoration: none;">
    <div class="logo-main">{{ settings.shop_name_override | default: shop.name | default: 'Zybuds' }}</div>
    {% if settings.shop_tagline != blank %}
      <div class="logo-sub">{{ settings.shop_tagline }}</div>
    {% endif %}
  </a>
  <div class="nav-links">
    <a href="{{ routes.root_url }}">Home</a>
    <a href="/collections/earbuds">Earbuds</a>
    <a href="/collections/smartwatches">Smartwatches</a>
    <a href="/pages/about">About</a>
  </div>
  <div class="nav-right">
    <button class="nav-order" onclick="handleOrder()">Order Now</button>
  </div>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>&nbsp;›&nbsp;
  {%- if template == 'product' -%}
    {%- if product.collections.first -%}
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>&nbsp;›&nbsp;
    {%- else -%}
      <a href="/collections/all">Earbuds &amp; Audio</a>&nbsp;›&nbsp;
    {%- endif -%}
    <span style="color:var(--ink2);">{{ product.title }}</span>
  {%- else -%}
    <span style="color:var(--ink2);">{{ page_title }}</span>
  {%- endif -%}
</div>
