<!-- ============================================================
   snippets/footer.liquid
   Site footer with brand info, nav columns, and bottom bar
   ============================================================ -->

{%- assign brand = settings.shop_name_override | default: shop.name | default: 'Zybuds' -%}
{%- assign city = settings.city | default: 'Hyderabad' -%}
{%- assign city_area = settings.city_area | default: 'Secunderabad' -%}
{%- assign founder_location = settings.founder_location | default: 'Suman Housing Colony, Secunderabad' -%}
{%- assign warranty = settings.warranty_years | default: '1' -%}

<footer>
  <div class="footer2-inner">
    <div class="f2-brand">
      <a href="{{ routes.root_url }}" class="logo f2-logo-link" style="text-decoration: none; margin-bottom: 12px;">
        <div class="logo-main" style="font-size: 22px;">{{ brand }}</div>
        {%- if settings.tagline != blank -%}
          <div class="logo-sub" style="font-size: 6px;">{{ settings.tagline }}</div>
        {%- endif -%}
      </a>
      <p>{{ city }}'s trusted local audio brand. Same-day delivery, open box, COD. Based in {{ city_area }} since 2024.</p>
    </div>

    <div class="f2-col">
      <h4>ABOUT</h4>
      <a href="/pages/about">{{ 'sections.footer.our_story' | t | default: 'Our Story' }}</a>
      {%- if settings.instagram_handle != blank -%}
        <a href="https://instagram.com/{{ settings.instagram_handle }}" target="_blank" rel="noopener">{{ 'sections.footer.instagram' | t | default: 'Instagram' }}</a>
      {%- endif -%}
      <a href="/pages/contact">{{ 'sections.footer.contact' | t | default: 'Contact' }}</a>
      <a href="/policies/privacy-policy">{{ 'sections.footer.privacy_policy' | t | default: 'Privacy Policy' }}</a>
    </div>
  </div>
  <div class="footer2-bottom">
    <div>© {{ 'now' | date: '%Y' }} {{ brand }} · {{ founder_location }}, {{ city }}</div>
    <div>📦 Open Box · 🚀 Same Day · 🛡️ {{ warranty }} Yr Warranty · 💰 COD</div>
  </div>
</footer>
