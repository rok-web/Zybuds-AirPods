<!-- ============================================================
   ZYBUDS — sections/product-main.liquid
   ============================================================ -->

<!-- HERO GRID -->
<div class="hero">

  <!-- LEFT — IMAGE PANEL -->
  <div class="img-panel">
    <div class="main-img" id="mainImgBox">
      <div class="main-img-glow"></div>
      <div class="img-tag-tl">✅ QC Tested</div>
      <div class="img-tag-tr">⚡ Same Day</div>

      <div class="product-img-wrap" id="productImgWrap">
        <div class="product-placeholder">
          {%- if product.featured_image -%}
            <img
              id="mainProductImg"
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="600"
              height="600"
              style="width:100%;max-width:340px;object-fit:contain;border-radius:12px;"
            >
          {%- else -%}
            <!-- Fallback SVG illustration when no product image is set -->
            <svg class="earbuds-svg" id="mainProductSvg" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
              <g transform="translate(50,80)">
                <ellipse cx="55" cy="110" rx="38" ry="52" fill="#1a1a1a" stroke="#2e2e2e" stroke-width="2"/>
                <ellipse cx="55" cy="110" rx="28" ry="40" fill="#141414"/>
                <circle cx="55" cy="110" r="16" fill="#0a0a0a" stroke="#333" stroke-width="1.5"/>
                <circle cx="55" cy="110" r="8" fill="#1c1c1c"/>
                <ellipse cx="55" cy="65" rx="14" ry="28" fill="#222" stroke="#2e2e2e" stroke-width="1.5"/>
                <circle cx="49" cy="108" r="1.5" fill="#333"/>
                <circle cx="55" cy="105" r="1.5" fill="#333"/>
                <circle cx="61" cy="108" r="1.5" fill="#333"/>
                <circle cx="55" cy="113" r="1.5" fill="#333"/>
                <circle cx="55" cy="110" r="21" fill="none" stroke="#e8c97a" stroke-width="0.8" opacity="0.6"/>
              </g>
              <g transform="translate(155,80)">
                <ellipse cx="55" cy="110" rx="38" ry="52" fill="#1a1a1a" stroke="#2e2e2e" stroke-width="2"/>
                <ellipse cx="55" cy="110" rx="28" ry="40" fill="#141414"/>
                <circle cx="55" cy="110" r="16" fill="#0a0a0a" stroke="#333" stroke-width="1.5"/>
                <circle cx="55" cy="110" r="8" fill="#1c1c1c"/>
                <ellipse cx="55" cy="65" rx="14" ry="28" fill="#222" stroke="#2e2e2e" stroke-width="1.5"/>
                <circle cx="49" cy="108" r="1.5" fill="#333"/>
                <circle cx="55" cy="105" r="1.5" fill="#333"/>
                <circle cx="61" cy="108" r="1.5" fill="#333"/>
                <circle cx="55" cy="113" r="1.5" fill="#333"/>
                <circle cx="55" cy="110" r="21" fill="none" stroke="#e8c97a" stroke-width="0.8" opacity="0.6"/>
              </g>
              <rect x="88" y="250" width="124" height="34" rx="17" fill="#181818" stroke="#282828" stroke-width="1.5"/>
              <line x1="148" y1="260" x2="154" y2="260" stroke="#e8c97a" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="150" cy="265" r="3" fill="none" stroke="#555" stroke-width="1"/>
            </svg>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Thumbnails -->
    <div class="thumbs-row">
      {%- if product.images.size > 0 -%}
        {%- for image in product.images limit: 4 -%}
          <div class="thumb2 {% if forloop.first %}active{% endif %}"
               onclick="switchToImage('{{ image | image_url: width: 600 }}', '{{ image.alt | escape }}', this)">
            <img src="{{ image | image_url: width: 120 }}"
                 alt="{{ image.alt | escape | default: product.title }}"
                 style="width:100%;height:100%;object-fit:cover;border-radius:10px;">
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- SVG fallback thumbnails when no product images -->
        <div class="thumb2 active" onclick="switchView('earbuds',this)">
          <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="13" cy="22" rx="7" ry="10" fill="#2a2a2a" stroke="#e8c97a" stroke-width="1"/>
            <ellipse cx="27" cy="22" rx="7" ry="10" fill="#2a2a2a" stroke="#555" stroke-width="1"/>
          </svg>
        </div>
        <div class="thumb2" onclick="switchView('case',this)">
          <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="12" width="28" height="20" rx="10" fill="#2a2a2a" stroke="#555" stroke-width="1"/>
            <line x1="18" y1="21" x2="22" y2="21" stroke="#e8c97a" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="thumb2" onclick="switchView('side',this)">
          <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="20" cy="22" rx="8" ry="11" fill="#2a2a2a" stroke="#555" stroke-width="1"/>
            <ellipse cx="20" cy="13" rx="4" ry="7" fill="#333" stroke="#555" stroke-width="1"/>
          </svg>
        </div>
        <div class="thumb2" onclick="switchView('cable',this)">
          <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 8 Q10 20 14 32" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round"/>
            <rect x="12" y="30" width="5" height="6" rx="1" fill="#2a2a2a" stroke="#555" stroke-width="1"/>
            <rect x="23" y="8" width="4" height="9" rx="2" fill="#2a2a2a" stroke="#e8c97a" stroke-width="1"/>
          </svg>
        </div>
      {%- endif -%}
    </div>

    <div class="img-stats-row">
      <div class="img-stat">
        <div class="s-num">{{ section.settings.orders_delivered }}</div>
        <div class="s-lbl">Delivered</div>
      </div>
      <div class="img-stat">
        <div class="s-num">4.9★</div>
        <div class="s-lbl">Avg Rating</div>
      </div>
      <div class="img-stat">
        <div class="s-num">1 Yr</div>
        <div class="s-lbl">Warranty</div>
      </div>
    </div>
  </div><!-- /img-panel -->

  <!-- RIGHT — INFO PANEL -->
  <div class="info-panel">
    <div class="editorial-label">Premium TWS · Hyderabad</div>

    <h1 class="p2-title">
      {%- assign title_parts = product.title | split: ' with ' -%}
      {%- if title_parts.size > 1 -%}
        {{ title_parts[0] }} <em>with {{ title_parts[1] }}</em>
      {%- else -%}
        {{ product.title }}
      {%- endif -%}
    </h1>

    <p class="p2-tagline">
      {{- product.description | strip_html | truncate: 180 -}}
    </p>

    <!-- Live Activity -->
    <div class="live-activity">
      <div class="la-item">
        <div class="la-dot"></div>
        <div>
          <div class="la-num" id="viewCount">47</div>
          <div style="font-size:10px;color:var(--muted);font-weight:600;letter-spacing:0.5px;text-transform:uppercase;">Viewing now</div>
        </div>
      </div>
      <div class="la-sep"></div>
      <div class="la-item">
        <div>
          <div class="la-num" id="orderCount">23</div>
          <div style="font-size:10px;color:var(--muted);font-weight:600;letter-spacing:0.5px;text-transform:uppercase;">Orders today</div>
        </div>
      </div>
      <div class="la-sep"></div>
      <div class="la-item">
        <div>
          <div class="la-num">4.9</div>
          <div style="font-size:10px;color:var(--muted);font-weight:600;letter-spacing:0.5px;text-transform:uppercase;">Avg rating</div>
        </div>
      </div>
    </div>

    <!-- PAYMENT OPTION TOGGLE -->
    <div class="opt2-label">Payment Option:</div>
    <div class="payment-options">
      <div class="pay-opt active" onclick="selectPayOption('advance', this)">
        <div class="po-title">Pay ₹99 Advance</div>
        <div class="po-sub">Rest on Delivery</div>
      </div>
      <div class="pay-opt" onclick="selectPayOption('full', this)">
        <div class="po-title">Pay Full {{ product.price | money }}</div>
        <div class="po-sub">Skip COD Process</div>
      </div>
    </div>

    <!-- PRICE BOX -->
    <div class="price-box2">
      <div class="price-box2-top">
        <div class="p2-main-price">
          <sup>{{ cart.currency.symbol }}</sup>{{ product.price | money_without_currency }}
        </div>
        {%- if product.compare_at_price > product.price -%}
          <div class="p2-old-price">{{ product.compare_at_price | money }}</div>
          <div class="p2-save-chip">
            Save {{ product.compare_at_price | minus: product.price | money }}
          </div>
        {%- endif -%}
      </div>
      <div id="priceBreakdown" class="price-breakdown">
        Pay <strong>₹99 now</strong> to confirm →
        Remaining <strong>{{ product.price | minus: 99 | money }} cash</strong> on delivery, after you check the product
      </div>
    </div>

    <!-- WHY ₹99 -->
    <div class="why99-box">
      <div class="why99-title">💡 Why do we ask for ₹99?</div>
      <div style="font-size: 13px; color: var(--ink2); line-height: 1.5; margin-bottom: 14px;">
        {{ section.settings.why99_text }}
      </div>
      <div class="why99-steps">
        <div class="why99-step">
          <div class="w99-icon">1</div>
          <div><strong>Pay ₹99 now</strong> — confirms you're genuine &amp; filters fake orders</div>
        </div>
        <div class="why99-step">
          <div class="w99-icon">2</div>
          <div>We call within <strong>30 minutes</strong> to confirm delivery time</div>
        </div>
        <div class="why99-step">
          <div class="w99-icon">3</div>
          <div>Delivery arrives — <strong>open &amp; fully check</strong> the product first</div>
        </div>
        <div class="why99-step">
          <div class="w99-icon">4</div>
          <div>Happy? Pay <strong>{{ product.price | minus: 99 | money }} cash</strong>. Not satisfied? Full ₹99 refund</div>
        </div>
      </div>
      <div class="why99-refund" style="border-top-color: rgba(232,201,122,0.3); margin-top: 14px; padding-top: 12px;">
        ✅ Not satisfied? We take the product back. Full ₹99 refunded. No questions, no drama.
      </div>
    </div>

    <!-- COLOR / VARIANT PICKER -->
    {%- if product.variants.size > 1 -%}
      {%- for option in product.options_with_values -%}
        <div class="opt2-label">{{ option.name }}: <span id="col2Name">{{ option.values.first }}</span></div>
        <div class="colors2">
          {%- for value in option.values -%}
            {%- assign color_class = value | downcase | replace: ' ', '' -%}
            <div class="col2 {{ color_class }}2 {% if forloop.first %}active{% endif %}"
                 title="{{ value }}"
                 onclick="pickCol2('{{ value }}', this)">
            </div>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="opt2-label">Color: <span id="col2Name">White</span></div>
      <div class="colors2">
        <div class="col2 white2 active" style="cursor: default;" title="White"></div>
      </div>
    {%- endif -%}

    <!-- STOCK / URGENCY -->
    <div class="stock2">
      <div class="sdot"></div>
      <div>
        {%- assign stock = product.selected_or_first_available_variant.inventory_quantity -%}
        {%- if stock > 0 and stock <= 10 -%}
          <span class="stock2-text">Only {{ stock }} pieces left</span>
        {%- elsif stock <= 0 -%}
          <span class="stock2-text">Currently out of stock</span>
        {%- else -%}
          <span class="stock2-text">In Stock — Ready to Ship</span>
        {%- endif -%}
        <span class="stock2-sub"> · <span id="dailyViewCount">19</span> people viewed this today</span>
      </div>
    </div>

    <!-- WARRANTY -->
    <div class="warranty-ribbon">
      <div class="wr-icon">🛡️</div>
      <div class="wr-text">
        <h4>{{ section.settings.warranty_title }}</h4>
        <p>{{ section.settings.warranty_text }}</p>
      </div>
      <div class="wr-badge">1 Year<br>Warranty</div>
    </div>

    <!-- ADD TO CART / ORDER BUTTON -->
    {%- form 'product', product, id: 'ProductForm', data-product-form: '' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      {%- comment -%} Hidden ₹99 advance variant logic — use JS to swap variant id based on pay option {%- endcomment -%}
      <input type="hidden" name="quantity" value="1">

      <button
        type="submit"
        class="btn2-primary"
        id="orderBtn"
        {%- unless product.selected_or_first_available_variant.available -%} disabled{%- endunless -%}
      >
        <span>
          {%- if product.selected_or_first_available_variant.available -%}
            🛒 Confirm Order — Pay ₹99
          {%- else -%}
            Out of Stock
          {%- endif -%}
        </span>
        <span class="btn-right">Same Day Delivery →</span>
      </button>
    {%- endform -%}

    <!-- GUARANTEE -->
    <div class="guarantee2">
      <div class="g2-title">🔒 Your Complete Protection</div>
      <div class="g2-grid">
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>Open Box Delivery</strong><br>Check before you pay</div>
        </div>
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>Same Day Hyderabad</strong><br>Order before 2 PM</div>
        </div>
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>₹99 Refundable</strong><br>Not happy? Full refund</div>
        </div>
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>1 Year Warranty</strong><br>Full product coverage</div>
        </div>
      </div>
    </div>

    <!-- TRUST BADGES -->
    <div class="trust2-row">
      <div class="t2"><span class="ti">📦</span><div class="tl">Open Box<br>Delivery</div></div>
      <div class="t2"><span class="ti">🚀</span><div class="tl">Same Day<br>Hyderabad</div></div>
      <div class="t2"><span class="ti">🛡️</span><div class="tl">1 Year<br>Warranty</div></div>
      <div class="t2"><span class="ti">💰</span><div class="tl">Cash on<br>Delivery</div></div>
    </div>
  </div><!-- /info-panel -->
</div><!-- /hero -->


<!-- ============================================================
   BELOW FOLD
   ============================================================ -->
<div class="below-fold">

  <!-- VIDEO SECTION -->
  {%- if section.settings.show_video_section -%}
  <div class="section2 section2-video reveal">
    <div class="sec2-eyebrow">See It In Action</div>
    <div class="sec2-title">Real <em>Unboxing</em></div>
    <p class="sec2-sub">Watch real customers test and receive their orders in Hyderabad.</p>
    <div class="video-strip">
      <div class="video-block">
        {%- if section.settings.video_url_1 != blank -%}
          <video autoplay muted loop playsinline style="width:100%;height:100%;object-fit:cover;display:block;">
            <source src="{{ section.settings.video_url_1 }}" type="video/mp4">
          </video>
        {%- else -%}
          <div class="video-ph" id="vh1">
            <div class="vid-play">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
            <div style="font-size:12px;color:var(--muted);font-weight:600;letter-spacing:0.5px;">Unboxing Video · Hyderabad</div>
          </div>
        {%- endif -%}
        <div class="video-overlay">
          <div class="video-caption">📦 Customer Unboxing — Open Box Delivery</div>
        </div>
      </div>
      <div class="video-block">
        {%- if section.settings.video_url_2 != blank -%}
          <video autoplay muted loop playsinline style="width:100%;height:100%;object-fit:cover;display:block;">
            <source src="{{ section.settings.video_url_2 }}" type="video/mp4">
          </video>
        {%- else -%}
          <div class="video-ph" id="vh2">
            <div class="vid-play">
              <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
            <div style="font-size:12px;color:var(--muted);font-weight:600;letter-spacing:0.5px;">Sound Demo · Bass Test</div>
          </div>
        {%- endif -%}
        <div class="video-overlay">
          <div class="video-caption">🎵 Deep Bass Sound Demo</div>
        </div>
      </div>
    </div>
  </div>
  {%- endif -%}

  <!-- FEATURES -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">Why Choose This</div>
    <div class="sec2-title">{{ section.settings.features_heading | default: 'Built for' }} <em>{{ section.settings.features_heading_em | default: 'Real Life' }}</em></div>
    <p class="sec2-sub">Four features that actually matter to your daily life.</p>
    <div class="feat2-grid">
      <div class="feat2">
        <span class="feat2-icon">🔇</span>
        <div class="feat2-title">Active Noise Cancellation</div>
        <div class="feat2-desc">Block out the Hyderabad traffic. Advanced ANC technology filters background noise so you can focus on your music.</div>
      </div>
      <div class="feat2">
        <span class="feat2-icon">🔋</span>
        <div class="feat2-title">40-Hour Total Battery</div>
        <div class="feat2-desc">8 hours in earbuds + 32 hours in the case. Survive your full week of commute without touching the charger.</div>
      </div>
      <div class="feat2">
        <span class="feat2-icon">🎧</span>
        <div class="feat2-title">3D Spatial Audio</div>
        <div class="feat2-desc">Experience sound like it's coming from all around you. Immersive 360-degree audio for movies and music.</div>
      </div>
      <div class="feat2">
        <span class="feat2-icon">📍</span>
        <div class="feat2-title">Find My Device (GPS)</div>
        <div class="feat2-desc">Never lose your AirPods again. Integrated GPS tracking works with Find My apps to pinpoint your earbuds' location.</div>
      </div>
    </div>
  </div>

  <!-- SPECS -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">Technical Details</div>
    <div class="sec2-title">Full <em>Specifications</em></div>
    <p class="sec2-sub">Everything you need to know before buying.</p>
    <div class="specs2-layout">
      <div class="spec2-table">
        {%- for block in section.blocks -%}
          {%- if block.type == 'spec_row' -%}
            <div class="spec2-row" {{ block.shopify_attributes }}>
              <span class="sk">{{ block.settings.spec_key }}</span>
              <span class="sv" {%- if block.settings.spec_highlight -%} style="color:var(--green);" {%- endif -%}>
                {{ block.settings.spec_value }}
              </span>
            </div>
          {%- endif -%}
        {%- endfor -%}
        {%- comment -%} Fallback static specs if no blocks defined {%- endcomment -%}
        {%- if section.blocks.size == 0 -%}
          <div class="spec2-row"><span class="sk">Features</span><span class="sv">ANC + GPS Tracking</span></div>
          <div class="spec2-row"><span class="sk">Drivers</span><span class="sv">13mm Pro Drivers</span></div>
          <div class="spec2-row"><span class="sk">Earbud Battery</span><span class="sv">8 Hours</span></div>
          <div class="spec2-row"><span class="sk">Case Battery</span><span class="sv">32 Hours</span></div>
          <div class="spec2-row"><span class="sk">Total Battery</span><span class="sv">40 Hours</span></div>
          <div class="spec2-row"><span class="sk">Microphone</span><span class="sv">Dual Noise Reduction</span></div>
          <div class="spec2-row"><span class="sk">Water Rating</span><span class="sv">IPX4 Sweat Proof</span></div>
          <div class="spec2-row"><span class="sk">Colors</span><span class="sv">White</span></div>
          <div class="spec2-row"><span class="sk">Compatibility</span><span class="sv">iOS + Android + PC</span></div>
          <div class="spec2-row"><span class="sk">Warranty</span><span class="sv" style="color:var(--green);">1 Full Year ✓</span></div>
        {%- endif -%}
      </div>
      <div class="spec2-visual">
        <svg class="spec-big-svg" viewBox="0 0 220 220" xmlns="http://www.w3.org/2000/svg">
          <rect x="20" y="70" width="180" height="120" rx="60" fill="#111" stroke="#222" stroke-width="2"/>
          <rect x="20" y="70" width="180" height="60" rx="30" fill="#151515" stroke="#282828" stroke-width="1.5"/>
          <ellipse cx="75" cy="110" rx="26" ry="36" fill="#0d0d0d" stroke="#2a2a2a" stroke-width="1.5"/>
          <circle cx="75" cy="110" r="10" fill="#181818"/>
          <circle cx="75" cy="110" r="4" fill="#1f1f1f" stroke="#e8c97a" stroke-width="0.5"/>
          <ellipse cx="145" cy="110" rx="26" ry="36" fill="#0d0d0d" stroke="#2a2a2a" stroke-width="1.5"/>
          <circle cx="145" cy="110" r="10" fill="#181818"/>
          <circle cx="145" cy="110" r="4" fill="#1f1f1f" stroke="#e8c97a" stroke-width="0.5"/>
          <circle cx="110" cy="176" r="4" fill="#e8c97a" opacity="0.8"/>
          <rect x="97" y="183" width="26" height="6" rx="3" fill="#1a1a1a" stroke="#333" stroke-width="1"/>
          <line x1="50" y1="130" x2="170" y2="130" stroke="#1e1e1e" stroke-width="1.5"/>
          <text x="110" y="58" text-anchor="middle" font-family="Georgia,serif" font-size="11" fill="#e8c97a" opacity="0.6" letter-spacing="3">ZYBUDS</text>
        </svg>
        <div class="spec-bullets">
          <div class="spec-bullet"><div class="sb-dot"></div>Real Working Pop-up</div>
          <div class="spec-bullet"><div class="sb-dot"></div>Active Noise Cancellation</div>
          <div class="spec-bullet"><div class="sb-dot"></div>GPS / Find My Device</div>
          <div class="spec-bullet"><div class="sb-dot"></div>13mm Hi-Fi Audio Drivers</div>
        </div>
      </div>
    </div>
  </div>

  <!-- BOX CONTENTS -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">In The Box</div>
    <div class="sec2-title">Everything <em>Included</em></div>
    <p class="sec2-sub">Unbox and start listening immediately — nothing extra to buy.</p>
    <div class="box2-grid">
      <div class="box2-item"><span class="box2-em">🎧</span>
        <div class="box2-name">{{ product.title | split: ' with ' | first }}</div>
        <div class="box2-qty">× 1 Pair</div>
      </div>
      <div class="box2-item"><span class="box2-em">📦</span>
        <div class="box2-name">Charging Case</div>
        <div class="box2-qty">× 1</div>
      </div>
      <div class="box2-item"><span class="box2-em">🔌</span>
        <div class="box2-name">USB-C Cable</div>
        <div class="box2-qty">× 1</div>
      </div>
      <div class="box2-item"><span class="box2-em">📄</span>
        <div class="box2-name">Warranty Card</div>
        <div class="box2-qty">× 1</div>
      </div>
    </div>
  </div>

  <!-- REVIEWS -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">Customer Reviews</div>
    <div class="sec2-title">Hyderabad <em>Speaks</em></div>
    <p class="sec2-sub">Real orders. Real deliveries. Real people across our city.</p>

    <div class="reviews2-header">
      <div class="big-score">
        <div class="big-score-num">4.9</div>
        <div class="big-score-stars">★★★★★</div>
        <div class="big-score-lbl">{{ section.settings.review_count | default: '2,140' }} verified reviews</div>
      </div>
      <div class="rbars2">
        <div class="rb2row"><span class="rb2lbl">5★</span><div class="rb2track"><div class="rb2fill" style="width:88%"></div></div><span class="rb2count">188</span></div>
        <div class="rb2row"><span class="rb2lbl">4★</span><div class="rb2track"><div class="rb2fill" style="width:9%"></div></div><span class="rb2count">19</span></div>
        <div class="rb2row"><span class="rb2lbl">3★</span><div class="rb2track"><div class="rb2fill" style="width:2%"></div></div><span class="rb2count">5</span></div>
        <div class="rb2row"><span class="rb2lbl">2★</span><div class="rb2track"><div class="rb2fill" style="width:1%"></div></div><span class="rb2count">2</span></div>
        <div class="rb2row"><span class="rb2lbl">1★</span><div class="rb2track"><div class="rb2fill" style="width:0%"></div></div><span class="rb2count">0</span></div>
      </div>
    </div>

    <div class="reviews2-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="rev2" {{ block.shopify_attributes }}>
            <div class="rev2-top">
              <div class="rev2-av" style="background:{{ block.settings.avatar_color }};">
                {{ block.settings.reviewer_name | slice: 0 }}
              </div>
              <div>
                <div class="rev2-name">{{ block.settings.reviewer_name }}</div>
                <div class="rev2-loc">📍 {{ block.settings.reviewer_location }}</div>
              </div>
            </div>
            <div class="rev2-stars">★★★★★</div>
            <div class="rev2-text">{{ block.settings.review_text }}</div>
            <div class="rev2-verified">✓ Verified Purchase</div>
            <div class="rev2-date">{{ block.settings.review_date }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Fallback static reviews if no blocks defined {%- endcomment -%}
      {%- assign has_reviews = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}{%- assign has_reviews = true -%}{%- endif -%}
      {%- endfor -%}
      {%- unless has_reviews -%}
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#c8410a,#e85d1a);">R</div>
            <div>
              <div class="rev2-name">Ravi Kumar</div>
              <div class="rev2-loc">📍 Ameerpet, Hyderabad</div>
            </div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">I was skeptical about the ₹99 advance at first, but it all made perfect sense once explained. The product arrived quickly, I tested it on the spot before paying, and the bass quality is genuinely impressive. Highly recommend!</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">4 days ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#1565c0,#42a5f5);">P</div>
            <div>
              <div class="rev2-name">Priya Reddy</div>
              <div class="rev2-loc">📍 Madhapur, Hyderabad</div>
            </div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">Ordered at 10 AM, delivered by 2 PM — genuinely same day! The sound quality blew me away. Tested everything before paying, the delivery person waited patiently. The 1-year warranty gave me extra confidence to buy.</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">1 week ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#1a7a3c,#4caf50);">S</div>
            <div>
              <div class="rev2-name">Sai Teja</div>
              <div class="rev2-loc">📍 LB Nagar, Hyderabad</div>
            </div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">This is my third order from Zybuds — smartwatch, power bank, now earbuds. Every single time: same day delivery, open box, everything working perfectly. The warranty coverage is a game-changer at this price point.</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">2 weeks ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#6a1b9a,#ab47bc);">A</div>
            <div>
              <div class="rev2-name">Ananya Singh</div>
              <div class="rev2-loc">📍 Begumpet, Hyderabad</div>
            </div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">Sound quality exceeded my expectations completely. The call mic is super clear — even tested it while riding an auto. The ₹99 system is actually clever and fair. Will definitely order again for my sister too.</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">3 weeks ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#e53935,#ef9a9a);">M</div>
            <div>
              <div class="rev2-name">Mohammed Farhan</div>
              <div class="rev2-loc">📍 Dilsukhnagar, Hyderabad</div>
            </div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">Saw this on Instagram and honestly expected it to be fake. But the open box delivery and 1-year warranty changed my mind. Everything is exactly as described. This is a real local Hyderabad business — fully trustworthy.</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">1 month ago</div>
        </div>
        <div class="rev2">
          <div class="rev2-top">
            <div class="rev2-av" style="background:linear-gradient(135deg,#00838f,#4dd0e1);">D</div>
            <div>
              <div class="rev2-name">Deepika Rao</div>
              <div class="rev2-loc">📍 Kondapur, Hyderabad</div>
            </div>
          </div>
          <div class="rev2-stars">★★★★★</div>
          <div class="rev2-text">Bought this as a gift for my husband — he is absolutely in love with it. Paired with his Samsung in seconds. Battery easily lasts his full work day. Knowing there's a 1-year warranty made it a completely stress-free purchase. ❤️</div>
          <div class="rev2-verified">✓ Verified Purchase</div>
          <div class="rev2-date">1 month ago</div>
        </div>
      {%- endunless -%}
    </div>
  </div>

  <!-- FAQ -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">Got Questions?</div>
    <div class="sec2-title">Frequently <em>Asked</em></div>
    <p class="sec2-sub">Honest answers — no fine print, no hidden surprises.</p>
    <div class="faq2-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          <div class="faq2-item" {{ block.shopify_attributes }}>
            <div class="faq2-q" onclick="toggleFaq2(this)">
              {{ block.settings.faq_question }}
              <div class="faq2-arr">+</div>
            </div>
            <div class="faq2-a">{{ block.settings.faq_answer }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Fallback static FAQs {%- endcomment -%}
      {%- assign has_faqs = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}{%- assign has_faqs = true -%}{%- endif -%}
      {%- endfor -%}
      {%- unless has_faqs -%}
        <div class="faq2-item open">
          <div class="faq2-q" onclick="toggleFaq2(this)">
            Why do you ask for ₹99 in advance?
            <div class="faq2-arr">+</div>
          </div>
          <div class="faq2-a">We ask for ₹99 purely to avoid fake orders. In the past, unverified customers placed orders for "timepass" with wrong addresses or didn't open the door — wasting our delivery person's time. Genuine members pay ₹99 because they really want the product. <strong>This is NOT an extra charge</strong> — it will be deducted from your final payment, so you still pay exactly ₹1,400 total. It's just a filter to avoid fake orders. This ₹99 advance acts as a security filter; if you aren't satisfied with the product upon delivery, the amount is fully refundable.</div>
        </div>
        <div class="faq2-item">
          <div class="faq2-q" onclick="toggleFaq2(this)">
            What exactly is open box delivery?
            <div class="faq2-arr">+</div>
          </div>
          <div class="faq2-a">Our delivery partner waits while you fully unbox and test the product. Connect to your phone, test sound, check mic, test the charging case — everything. Only when you're satisfied do you pay the remaining cash. If anything's wrong, send it back immediately. Zero risk.</div>
        </div>
        <div class="faq2-item">
          <div class="faq2-q" onclick="toggleFaq2(this)">
            What does the 1 Year Warranty cover?
            <div class="faq2-arr">+</div>
          </div>
          <div class="faq2-a">Our 1 Year Seller Warranty covers all manufacturing defects — if earbuds stop working, charging fails, or sound drops within 12 months, we replace or repair. Just WhatsApp us with a video of the issue. Personal promise from our founder — we stand behind every product we sell.</div>
        </div>
        <div class="faq2-item">
          <div class="faq2-q" onclick="toggleFaq2(this)">
            How fast is delivery? Which areas do you cover?
            <div class="faq2-arr">+</div>
          </div>
          <div class="faq2-a">Order before 2 PM — delivered same day. Order after 2 PM — delivered next morning. We cover all of Hyderabad: Secunderabad, Ameerpet, LB Nagar, Dilsukhnagar, Kondapur, Madhapur, Begumpet, Uppal, Himayatnagar, SR Nagar, Tarnaka, and more.</div>
        </div>
        <div class="faq2-item">
          <div class="faq2-q" onclick="toggleFaq2(this)">
            Who is Zybuds? Are you a real business?
            <div class="faq2-arr">+</div>
          </div>
          <div class="faq2-a">100% real. Zybuds is based in Secunderabad, Suman Housing Colony, Hyderabad. We have 5,089+ completed orders across the city. You can find our delivery videos and unboxings on Instagram. We respond immediately. Our founder personally handles every warranty issue.</div>
        </div>
      {%- endunless -%}
    </div>
  </div>
</div><!-- /below-fold -->

<!-- FOUNDER SECTION -->
<div style="max-width:1440px;margin:0 auto;padding:0 5%;">
  <div class="founder2 reveal">
    <div class="founder2-av">{{ section.settings.founder_initial | default: 'M' }}</div>
    <div class="founder2-content">
      <div class="founder2-eyebrow">A Message From Our Founder</div>
      <div class="founder2-title">{{ section.settings.founder_greeting | default: "Hi, I'm Mahesh." }}<br>{{ section.settings.founder_subtitle | default: 'I run Zybuds from Secunderabad.' }}</div>
      <div class="founder2-text">{{ section.settings.founder_message }}</div>
      <div class="founder2-meta">
        <div class="f2-chip">👤 {{ section.settings.founder_name | default: 'Mahesh, Founder' }}</div>
        <div class="f2-chip">📍 {{ section.settings.founder_location | default: 'Suman Housing Colony, Secunderabad' }}</div>
        <div class="f2-chip">🏙️ Hyderabad, Telangana</div>
        <div class="f2-chip">🛡️ 1 Year Warranty on All Products</div>
      </div>
    </div>
  </div>
</div>

<!-- Pass Shopify product data to JS -->
<script>
  window.ShopifyProduct = {
    id: {{ product.id }},
    title: {{ product.title | json }},
    price: {{ product.price }},
    compareAtPrice: {{ product.compare_at_price | default: 0 }},
    variantId: {{ product.selected_or_first_available_variant.id }},
    currency: {{ cart.currency.symbol | json }},
    available: {{ product.selected_or_first_available_variant.available }}
  };
</script>


