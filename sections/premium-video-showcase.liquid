{%- style -%}
  .premium-video-section {
    padding: 60px 5%;
    background: #000;
    color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .premium-video-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .pvs-header {
    margin-bottom: 40px;
  }

  .pvs-title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .pvs-subtitle {
    font-size: clamp(16px, 2vw, 20px);
    color: #86868b;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .pvs-video-wrapper {
    position: relative;
    width: 100%;
    border-radius: 28px;
    overflow: hidden;
    background: #1d1d1f;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    aspect-ratio: 16 / 9;
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .pvs-video-wrapper:hover {
    transform: scale(1.01);
  }

  .pvs-video-wrapper video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .pvs-video-wrapper video.loaded {
    opacity: 1;
  }

  .pvs-poster {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .pvs-video-wrapper video.loaded + .pvs-poster {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .premium-video-section {
      padding: 40px 20px;
    }
    .pvs-video-wrapper {
      border-radius: 18px;
    }
  }
{%- endstyle -%}

<section class="premium-video-section" id="section-{{ section.id }}">
  <div class="premium-video-container">
    {% if section.settings.title != blank or section.settings.subtitle != blank %}
      <div class="pvs-header">
        {% if section.settings.title != blank %}
          <h2 class="pvs-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
          <p class="pvs-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="pvs-video-wrapper" id="video-wrapper-{{ section.id }}">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: 
          autoplay: false, 
          loop: true, 
          muted: true, 
          playsinline: true, 
          controls: false,
          preload: "metadata",
          class: "premium-video-element"
        }}
      {%- elsif section.settings.video_url != blank -%}
        <video 
          src="{{ section.settings.video_url }}" 
          muted 
          loop 
          playsinline 
          preload="metadata" 
          class="premium-video-element">
        </video>
      {%- endif -%}

      {%- if section.settings.poster != blank -%}
        <img src="{{ section.settings.poster | image_url: width: 1200 }}" alt="" class="pvs-poster" loading="lazy">
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('#section-{{ section.id }}');
    const video = section.querySelector('.premium-video-element');
    const wrapper = section.querySelector('.pvs-video-wrapper');

    if (!video) return;

    // Hover Restart Behavior
    wrapper.addEventListener('mouseenter', () => {
      video.currentTime = 0;
      video.play();
    });

    // Fade in when loaded
    video.addEventListener('loadeddata', () => {
      video.classList.add('loaded');
    });

    // Ensure muted is forced (browser compliance)
    video.muted = true;
  })();
</script>

{% schema %}
{
  "name": "Premium Video Showcase",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Experience Innovation"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subheading",
      "default": "A closer look at the craftsmanship and technology behind the scenes."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify Hosted Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "External Video URL (MP4)",
      "info": "Used if no Shopify video is selected."
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster Image",
      "info": "Displays while video is loading."
    }
  ],
  "presets": [
    {
      "name": "Premium Video Showcase"
    }
  ]
}
{% endschema %}
