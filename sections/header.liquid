<!-- ============================================================
   ZYBUDS — sections/header.liquid
   Ticker + Navbar + Breadcrumb
   ============================================================ -->

<!-- TICKER -->
<div class="ticker-wrap">
  <div class="ticker-track">
    <span>🚀 Same Day Delivery — All {{ settings.city | default: 'Hyderabad' }}</span><span class="dot">✦</span>
    <span>📦 Open Box — Check Before You Pay</span><span class="dot">✦</span>
    <span>🛡️ {{ settings.warranty_years | default: '1' }} Year Warranty Included</span><span class="dot">✦</span>
    <span>💰 COD Available — Pay ₹{{ settings.advance_amount | default: '99' }} to Confirm</span><span class="dot">✦</span>
    <span>📍 Based in {{ settings.city_area | default: 'Secunderabad' }}, {{ settings.city | default: 'Hyderabad' }}</span><span class="dot">✦</span>
    <span>{{ settings.orders_delivered | default: '500+' }} Orders Delivered</span><span class="dot">✦</span>
    <span>🚀 Same Day Delivery — All {{ settings.city | default: 'Hyderabad' }}</span><span class="dot">✦</span>
    <span>📦 Open Box — Check Before You Pay</span><span class="dot">✦</span>
    <span>🛡️ {{ settings.warranty_years | default: '1' }} Year Warranty Included</span><span class="dot">✦</span>
    <span>💰 COD Available — Pay ₹{{ settings.advance_amount | default: '99' }} to Confirm</span><span class="dot">✦</span>
    <span>📍 Based in {{ settings.city_area | default: 'Secunderabad' }}, {{ settings.city | default: 'Hyderabad' }}</span><span class="dot">✦</span>
    <span>{{ settings.orders_delivered | default: '500+' }} Orders Delivered</span><span class="dot">✦</span>
  </div>
</div>

<!-- NAVBAR -->
<nav>
  <a href="{{ routes.root_url }}" class="logo" style="text-decoration: none;">
    <div class="logo-main">{{ settings.shop_name_override | default: shop.name | default: 'Zybuds' }}</div>
    {%- if settings.tagline != blank -%}
      <div class="logo-sub">{{ settings.tagline }}</div>
    {%- endif -%}
  </a>
  <div class="nav-links">
    <a href="{{ routes.root_url }}">{{ 'sections.header.home' | t }}</a>
    <a href="/collections/earbuds">{{ 'sections.header.earbuds' | t }}</a>
    <a href="/collections/smartwatches">{{ 'sections.header.smartwatches' | t }}</a>
    <a href="/pages/about">{{ 'sections.header.about' | t }}</a>
  </div>
  <div class="nav-right">
    <button class="nav-order" onclick="handleOrder()">{{ 'sections.header.order_now' | t }}</button>
  </div>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>&nbsp;›&nbsp;
  {%- if template == 'product' -%}
    {%- if product.collections.first -%}
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>&nbsp;›&nbsp;
    {%- else -%}
      <a href="/collections/all">Earbuds &amp; Audio</a>&nbsp;›&nbsp;
    {%- endif -%}
    <span style="color:var(--ink2);">{{ product.title }}</span>
  {%- else -%}
    <span style="color:var(--ink2);">{{ page_title }}</span>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Header",
  "class": "header-section",
  "settings": []
}
{% endschema %}
