<!-- ============================================================
   ZYBUDS — sections/product-page.liquid
   Complete product landing page section
   ============================================================ -->

{%- assign product_obj = product | default: section.settings.product -%}
{%- assign advance_raw = settings.advance_amount | default: 99 | plus: 0 -%}
{%- assign advance_cents = advance_raw | times: 100 -%}
{%- assign city = settings.city | default: 'Hyderabad' -%}
{%- assign warranty = settings.warranty_years | default: '1' -%}

{%- if product_obj and product_obj.id != blank -%}
  {%- assign remaining = product_obj.price | minus: advance_cents -%}
  {%- assign has_product = true -%}
{%- else -%}
  {%- assign remaining = 140000 | minus: advance_cents -%}
  {%- assign has_product = false -%}
{%- endif -%}

<!-- HERO GRID -->
<div class="hero">

  <!-- LEFT — IMAGE PANEL -->
  <div class="img-panel">
    <!-- Product image switcher snippet -->
    {%- assign custom_images = section.blocks | where: "type", "gallery_image" -%}
    {% render 'product-image-gallery', 
      product: product_obj, 
      custom_images: custom_images,
      gallery_img_1: section.settings.gallery_img_1,
      gallery_img_2: section.settings.gallery_img_2,
      gallery_img_3: section.settings.gallery_img_3,
      gallery_img_4: section.settings.gallery_img_4
    %}
  </div>

  <!-- RIGHT — INFO PANEL -->
  <div class="info-panel">
    <div class="editorial-label">Premium TWS · Hyderabad</div>

    <h1 class="p2-title">
      Zybuds AirPods Pro 2 with ANC + GPS Tracking and 13mm Drivers
    </h1>

    <p class="p2-tagline">
      {%- if product_obj -%}
        {{ product_obj.description | strip_html | truncatewords: 30 }}
      {%- else -%}
        We deliver across {{ city }} with open box COD. In the past, some customers placed fake orders for "timepass" — our delivery person would travel across the city, and the customer wouldn't answer the door. This wasted large amount of time and money.
      {%- endif -%}
    </p>

    <!-- Live Activity -->
    {% render 'live-activity' %}

    <!-- PAYMENT OPTION TOGGLE -->
    <div class="opt2-label">Payment Option:</div>
    <div class="payment-options">
      <div class="pay-opt advance-opt active" onclick="selectPayOption('advance', this)">
        <div class="po-title">Pay ₹{{ advance_raw }} Advance</div>
        <div class="po-sub">Rest on Delivery</div>
      </div>
      <div class="pay-opt full-opt" onclick="selectPayOption('full', this)">
        <div class="po-title">Pay Full {%- if product_obj -%}{{ product_obj.price | money }}{%- else -%}₹1,400{%- endif -%}</div>
        <div class="po-sub">Skip COD Process</div>
      </div>
    </div>

    <!-- PRICE BOX -->
    <div class="price-box2">
      <div class="price-box2-top">
        <div class="p2-main-price">
          {%- if product_obj -%}
            {{ product_obj.price | money }}
          {%- else -%}
            <sup>₹</sup>1,400
          {%- endif -%}
        </div>
        {%- if product_obj and product_obj.compare_at_price > product_obj.price -%}
          <div class="p2-old-price">{{ product_obj.compare_at_price | money }}</div>
          <div class="p2-save-chip">
            Save {{ product_obj.compare_at_price | minus: product_obj.price | money }}
          </div>
        {%- elsif product_obj == nil -%}
          <div class="p2-old-price">₹3,499</div>
          <div class="p2-save-chip">Save ₹2,099</div>
        {%- endif -%}
      </div>
      <div id="priceBreakdown" class="price-breakdown">
        Pay <strong>₹{{ advance_raw }} now</strong> to confirm →
        Remaining <strong>{{ remaining | money_without_trailing_zeros }} cash</strong> on delivery, after you check the product
      </div>
    </div>

    <!-- WHY ₹99 -->
    {% render 'why99-box' %}

    <!-- COLOR / VARIANT PICKER -->
    {%- if product_obj and product_obj.variants.size > 1 -%}
      {%- for option in product_obj.options_with_values -%}
        <div class="opt2-label">{{ option.name }}: <span id="col2Name">{{ option.selected_value | default: option.values.first }}</span></div>
        <div class="colors2">
          {%- for value in option.values -%}
            {%- assign color_class = value | downcase | replace: ' ', '' -%}
            <div class="col2 {{ color_class }}2 {% if forloop.first %}active{% endif %}"
                 title="{{ value }}"
                 onclick="pickCol2('{{ value }}', this)">
            </div>
          {%- endfor -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="opt2-label">Color: <span id="col2Name">White</span></div>
      <div class="colors2">
        <div class="col2 white2 active" title="White" onclick="pickCol2('White', this)"></div>
      </div>
    {%- endif -%}

    <!-- STOCK / URGENCY -->
    <div class="stock2">
      <div class="sdot"></div>
      <div>
        {%- if product_obj -%}
          {%- assign stock = product_obj.selected_or_first_available_variant.inventory_quantity -%}
          {%- if stock > 0 and stock <= 10 -%}
            <span class="stock2-text">Only {{ stock }} pieces left</span>
          {%- elsif stock <= 0 -%}
            <span class="stock2-text">Only 7 pieces left</span>
          {%- else -%}
            <span class="stock2-text">In Stock — Ready to Ship</span>
          {%- endif -%}
        {%- else -%}
          <span class="stock2-text">Only 7 pieces left</span>
        {%- endif -%}
        <span class="stock2-sub"> · <span id="dailyViewCount">19</span> people viewed this today</span>
      </div>
    </div>

    <!-- WARRANTY -->
    <div class="warranty-ribbon">
      <div class="wr-icon">🛡️</div>
      <div class="wr-text">
        <h4>{{ warranty }} Year Full Warranty — Included</h4>
        <p>Anything fails within {{ warranty | times: 12 }} months, we replace or fix it. No questions asked.</p>
      </div>
      <div class="wr-badge">{{ warranty }} Year<br>Warranty</div>
    </div>

    <!-- PRODUCT FORM -->
    <div class="product-form-container">
      {%- if has_product -%}
        {%- form 'product', product_obj, id: 'ProductForm', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ product_obj.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <input type="hidden" name="properties[Payment Type]" value="Advance" id="paymentTypeInput">
          
          <button type="submit" class="btn2-primary" id="orderBtn">
            <span>🛒 Confirm Order — Pay ₹{{ advance_raw }}</span>
            <span class="btn-right">Same Day Delivery →</span>
          </button>
        {%- endform -%}
      {%- else -%}
        <div class="no-product-warning" style="margin-bottom:10px; color:var(--red); font-size:12px; font-weight:700;">Please select a product in Theme Editor</div>
        <button class="btn2-primary" id="orderBtn" onclick="handleOrder()">
          <span>🛒 Confirm Order — Pay ₹{{ advance_raw }}</span>
          <span class="btn-right">Same Day Delivery →</span>
        </button>
      {%- endif -%}
    </div>

    <!-- GUARANTEE -->
    <div class="guarantee2">
      <div class="g2-title">🔒 Your Complete Protection</div>
      <div class="g2-grid">
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>Open Box Delivery</strong><br>Check before you pay</div>
        </div>
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>Same Day {{ city }}</strong><br>Order before 2 PM</div>
        </div>
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>₹{{ advance }} Refundable</strong><br>Not happy? Full refund</div>
        </div>
        <div class="g2-item"><span class="g2-check">✅</span>
          <div><strong>{{ warranty }} Year Warranty</strong><br>Full product coverage</div>
        </div>
      </div>
    </div>

    <!-- TRUST BADGES -->
    <div class="trust2-row">
      <div class="t2"><span class="ti">📦</span>
        <div class="tl">Open Box<br>Delivery</div>
      </div>
      <div class="t2"><span class="ti">🚀</span>
        <div class="tl">Same Day<br>{{ city }}</div>
      </div>
      <div class="t2"><span class="ti">🛡️</span>
        <div class="tl">{{ warranty }} Year<br>Warranty</div>
      </div>
      <div class="t2"><span class="ti">💰</span>
        <div class="tl">Cash on<br>Delivery</div>
      </div>
    </div>
  </div><!-- /info-panel -->
</div><!-- /hero -->


<!-- ============================================================
   BELOW FOLD
   ============================================================ -->
<div class="below-fold">

  <!-- FEATURES -->

  <!-- FEATURES -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">Why Choose This</div>
    <div class="sec2-title">Smart Features <em>That Work</em></div>
    <p class="sec2-sub">Watch each feature in action before you order.</p>
    <div class="feat2-grid">
      <div class="feat2">
        <div class="feat2-video">
          {%- assign v1_obj = section.settings.feat_video_1 -%}
          {%- assign v1_url = section.settings.video_url_1 -%}
          
          {%- if v1_obj != blank -%}
            {{ v1_obj | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
          {%- elsif v1_url != blank -%}
            {%- if v1_url contains 'drive.google.com' -%}
              {%- assign v1_id = v1_url | split: '/d/' | last | split: '/' | first | split: '?' | first -%}
              {%- assign v1_url = 'https://drive.google.com/uc?export=download&id=' | append: v1_id -%}
            {%- endif -%}
            <video src="{{ v1_url }}" autoplay muted loop playsinline preload="metadata"></video>
          {%- else -%}
            <div class="feat2-video-empty">Working Pop-Up Clip</div>
          {%- endif -%}
        </div>
        <div class="feat2-content">
          <div class="feat2-title">Working Pop-Up</div>
          <div class="feat2-desc">Open the case near your phone and connect quickly with the familiar pop-up pairing flow.</div>
        </div>
      </div>
      <div class="feat2">
        <div class="feat2-video">
          {%- assign v2_obj = section.settings.feat_video_2 -%}
          {%- assign v2_url = section.settings.video_url_2 -%}
          
          {%- if v2_obj != blank -%}
            {{ v2_obj | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
          {%- elsif v2_url != blank -%}
            {%- if v2_url contains 'drive.google.com' -%}
              {%- assign v2_id = v2_url | split: '/d/' | last | split: '/' | first | split: '?' | first -%}
              {%- assign v2_url = 'https://drive.google.com/uc?export=download&id=' | append: v2_id -%}
            {%- endif -%}
            <video src="{{ v2_url }}" autoplay muted loop playsinline preload="metadata"></video>
          {%- else -%}
            <div class="feat2-video-empty">Active Noise Cancellation Clip</div>
          {%- endif -%}
        </div>
        <div class="feat2-content">
          <div class="feat2-title">Active Noise Cancellation</div>
          <div class="feat2-desc">Reduce outside noise during calls, travel, and daily listening so your audio feels cleaner.</div>
        </div>
      </div>
      <div class="feat2">
        <div class="feat2-video">
          {%- assign v3_obj = section.settings.feat_video_3 -%}
          {%- assign v3_url = section.settings.video_url_3 -%}
          
          {%- if v3_obj != blank -%}
            {{ v3_obj | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
          {%- elsif v3_url != blank -%}
            {%- if v3_url contains 'drive.google.com' -%}
              {%- assign v3_id = v3_url | split: '/d/' | last | split: '/' | first | split: '?' | first -%}
              {%- assign v3_url = 'https://drive.google.com/uc?export=download&id=' | append: v3_id -%}
            {%- endif -%}
            <video src="{{ v3_url }}" autoplay muted loop playsinline preload="metadata"></video>
          {%- else -%}
            <div class="feat2-video-empty">Find My Device Clip</div>
          {%- endif -%}
        </div>
        <div class="feat2-content">
          <div class="feat2-title">Find My Device</div>
          <div class="feat2-desc">Locate your earbuds from your phone when they are misplaced, with a simple device-finding view.</div>
        </div>
      </div>
      <div class="feat2">
        <div class="feat2-video">
          {%- assign v4_obj = section.settings.feat_video_4 -%}
          {%- assign v4_url = section.settings.video_url_4 -%}
          
          {%- if v4_obj != blank -%}
            {{ v4_obj | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
          {%- elsif v4_url != blank -%}
            {%- if v4_url contains 'drive.google.com' -%}
              {%- assign v4_id = v4_url | split: '/d/' | last | split: '/' | first | split: '?' | first -%}
              {%- assign v4_url = 'https://drive.google.com/uc?export=download&id=' | append: v4_id -%}
            {%- endif -%}
            <video src="{{ v4_url }}" autoplay muted loop playsinline preload="metadata"></video>
          {%- else -%}
            <div class="feat2-video-empty">Touch Controls Clip</div>
          {%- endif -%}
        </div>
        <div class="feat2-content">
          <div class="feat2-title">Touch Controls</div>
          <div class="feat2-desc">Swipe or press to adjust volume, play or pause music, and answer or end calls.</div>
        </div>
      </div>

    </div>
  </div>

    <!-- WHAT OUR CUSTOMER SAYS: WhatsApp Reviews -->
    <!-- Add the WhatsApp Reviews section via the Shopify Theme Editor (Customize) as a new section after Features. -->

  <!-- SPECS -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">Technical Details</div>
    <div class="sec2-title">Full <em>Specifications</em></div>
    <p class="sec2-sub">Everything you need to know before buying.</p>
    <div class="specs2-layout">
      <div class="spec2-table">
        <div class="spec2-row"><span class="sk">Features</span><span class="sv">Pop-Up + ANC + Find My + 3D Audio</span></div>
        <div class="spec2-row"><span class="sk">Drivers</span><span class="sv">13mm Pro Drivers</span></div>
        <div class="spec2-row"><span class="sk">Earbud Battery</span><span class="sv">8 Hours</span></div>
        <div class="spec2-row"><span class="sk">Case Battery</span><span class="sv">32 Hours</span></div>
        <div class="spec2-row"><span class="sk">Total Battery</span><span class="sv">40 Hours</span></div>
        <div class="spec2-row"><span class="sk">Microphone</span><span class="sv">Dual Noise Reduction</span></div>
        <div class="spec2-row"><span class="sk">Water Rating</span><span class="sv">IPX4 Sweat Proof</span></div>
        <div class="spec2-row"><span class="sk">Compatibility</span><span class="sv">iOS + Android + PC</span></div>
        <div class="spec2-row"><span class="sk">Warranty</span><span class="sv" style="color:var(--green);">{{ warranty }} Full Year ✓</span></div>
      </div>
    </div>
  </div>

  <!-- BOX CONTENTS -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">In The Box</div>
    <div class="sec2-title">Everything <em>Included</em></div>
    <p class="sec2-sub">Unbox and start listening immediately — nothing extra to buy.</p>
    <div class="box2-grid">
      <div class="box2-item">
        {% if section.settings.box_img_1 %}
          <img src="{{ section.settings.box_img_1 | image_url: width: 120 }}" alt="Earbuds" class="box2-img" />
        {% else %}
          <span class="box2-em">🎧</span>
        {% endif %}
        <div class="box2-name">{{ product.title | split: ' with ' | first }}</div>
        <div class="box2-qty">× 1 Pair</div>
      </div>
      <div class="box2-item">
        {% if section.settings.box_img_2 %}
          <img src="{{ section.settings.box_img_2 | image_url: width: 120 }}" alt="Charging Case" class="box2-img" />
        {% else %}
          <span class="box2-em">📦</span>
        {% endif %}
        <div class="box2-name">Charging Case</div>
        <div class="box2-qty">× 1</div>
      </div>
      <div class="box2-item">
        {% if section.settings.box_img_3 %}
          <img src="{{ section.settings.box_img_3 | image_url: width: 120 }}" alt="USB-C Cable" class="box2-img" />
        {% else %}
          <span class="box2-em">🔌</span>
        {% endif %}
        <div class="box2-name">USB-C Cable</div>
        <div class="box2-qty">× 1</div>
      </div>
      <div class="box2-item">
        {% if section.settings.box_img_4 %}
          <img src="{{ section.settings.box_img_4 | image_url: width: 120 }}" alt="Warranty Card" class="box2-img" />
        {% else %}
          <span class="box2-em">📄</span>
        {% endif %}
        <div class="box2-name">User Manual</div>
        <div class="box2-qty">× 1</div>
      </div>
    </div>
  </div>

  <!-- REVIEWS -->
  {% render 'reviews' %}

  <!-- CUSTOMER VIDEO GALLERY -->
  <div class="section2 reveal">
    <div class="sec2-eyebrow">Visual Proof</div>
    <div class="sec2-title">{{ section.settings.cv_heading | default: 'Our Customer Review' }}</div>
    <p class="sec2-sub">Watch how our customers across Hyderabad are using their Zybuds.</p>
    
    <div class="cv-grid">
      {%- for i in (1..5) -%}
        {%- assign v_id = 'cv_video_' | append: i -%}
        {%- assign v_obj = section.settings[v_id] -%}
        <div class="cv-item">
          {%- if v_obj != blank -%}
            {{ v_obj | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
          {%- else -%}
            <div class="cv-placeholder">Video {{ i }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <!-- FAQ -->
  {% render 'faq' %}

</div><!-- /below-fold -->

<!-- FOUNDER SECTION -->
{% render 'founder' %}

<!-- Pass Shopify product data to JS -->
{%- if product_obj -%}
<script>
  window.ShopifyProduct = {
    id: {{ product_obj.id | json }},
    title: {{ product_obj.title | json }},
    price: {{ product_obj.price | default: 0 }},
    compareAtPrice: {{ product_obj.compare_at_price | default: 0 }},
    variantId: {{ product_obj.selected_or_first_available_variant.id | json }},
    advanceAmount: {{ settings.advance_amount | default: 99 }},
    currency: {{ cart.currency.symbol | json }},
    available: {{ product_obj.selected_or_first_available_variant.available | default: false }}
  };
</script>
{%- endif -%}




{% schema %}
{
  "name": "Product Page",
  "tag": "div",
  "class": "product-page-section",
  "settings": [
    {
      "type": "header",
      "content": "Main Product Gallery",
      "info": "Upload real images to replace the illustration boxes."
    },
    { "type": "image_picker", "id": "gallery_img_1", "label": "Gallery Image 1 (Earbuds)" },
    { "type": "image_picker", "id": "gallery_img_2", "label": "Gallery Image 2 (Charging Case)" },
    { "type": "image_picker", "id": "gallery_img_3", "label": "Gallery Image 3 (Side View)" },
    { "type": "image_picker", "id": "gallery_img_4", "label": "Gallery Image 4 (USB-C Cable)" },
    {
      "type": "header",
      "content": "Box Contents Images"
    },
    { "type": "image_picker", "id": "box_img_1", "label": "Earbuds Image (In The Box)", "info": "Optional: Upload real image for earbuds." },
    { "type": "image_picker", "id": "box_img_2", "label": "Charging Case Image (In The Box)", "info": "Optional: Upload real image for charging case." },
    { "type": "image_picker", "id": "box_img_3", "label": "USB-C Cable Image (In The Box)", "info": "Optional: Upload real image for USB-C cable." },
    { "type": "image_picker", "id": "box_img_4", "label": "Warranty Card Image (In The Box)", "info": "Optional: Upload real image for warranty card." },
    {
      "type": "product",
      "id": "product",
      "label": "Select Product",
      "info": "Choose the product to display on the landing page."
    },
    {
      "type": "header",
      "content": "Store Stats"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Total Reviews Count",
      "info": "Displayed in the reviews section header",
      "default": "214"
    },
    {
      "type": "header",
      "content": "Feature Videos"
    },
    {
      "type": "checkbox",
      "id": "show_video_section",
      "label": "Show Video Section",
      "default": true
    },
    {
      "type": "header",
      "content": "Feature Videos"
    },
    { "type": "video", "id": "feat_video_1", "label": "Working Pop-Up Video (Shopify Upload)" },
    { "type": "video", "id": "feat_video_2", "label": "ANC Video (Shopify Upload)" },
    { "type": "video", "id": "feat_video_3", "label": "Find My Video (Shopify Upload)" },
    { "type": "video", "id": "feat_video_4", "label": "Touch Controls Video (Shopify Upload)" },
    {
      "type": "text",
      "id": "video_url_1",
      "label": "Working Pop-Up Video URL (External)",
      "info": "Used if no Shopify video is selected."
    },
    {
      "type": "text",
      "id": "video_url_2",
      "label": "ANC Video URL (External)"
    },
    {
      "type": "text",
      "id": "video_url_3",
      "label": "Find My Device Video URL (External)"
    },
    {
      "type": "text",
      "id": "video_url_4",
      "label": "Touch Controls Video URL (External)"
    },

    {
      "type": "header",
      "content": "Founder Section"
    },
    {
      "type": "image_picker",
      "id": "founder_image",
      "label": "Founder Photo",
      "info": "Optional: upload a square photo of the founder."
    },
    {
      "type": "textarea",
      "id": "founder_message",
      "label": "Founder Message",
      "info": "Leave as is for auto-generated message using global settings.",
      "default": "Hi, I'm Mahesh. I run Zybuds from Secunderabad."
    },
    {
      "type": "header",
      "content": "Customer Video Reviews"
    },
    {
      "type": "text",
      "id": "cv_heading",
      "label": "Video Gallery Heading",
      "default": "Our Customer Review"
    },
    { "type": "video", "id": "cv_video_1", "label": "Customer Video 1" },
    { "type": "video", "id": "cv_video_2", "label": "Customer Video 2" },
    { "type": "video", "id": "cv_video_3", "label": "Customer Video 3" },
    { "type": "video", "id": "cv_video_4", "label": "Customer Video 4" },
    { "type": "video", "id": "cv_video_5", "label": "Customer Video 5" }
  ],
  "blocks": [
    {
      "type": "spec_row",
      "name": "Spec Row",
      "settings": [
        {
          "type": "text",
          "id": "spec_key",
          "label": "Spec Name",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "spec_value",
          "label": "Spec Value",
          "default": "Value"
        },
        {
          "type": "checkbox",
          "id": "spec_highlight",
          "label": "Highlight in green",
          "default": false
        }
      ]
    },
    {
      "type": "review",
      "name": "Customer Review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Ravi Kumar"
        },
        {
