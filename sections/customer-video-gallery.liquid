{%- style -%}
  .cv-gallery-{{ section.id }} {
    padding: 60px 5%;
    background: #000;
  }

  .cv-gallery-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .cv-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .cv-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 900;
    color: #fff;
    margin-bottom: 12px;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .cv-item {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #111;
    aspect-ratio: 9 / 16; /* Portrait for customer reviews usually */
    border: 1px solid rgba(255,255,255,0.1);
  }

  .cv-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 991px) {
    .cv-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .cv-grid {
      gap: 12px;
    }
    .cv-item {
      border-radius: 12px;
    }
  }
{%- endstyle -%}

<section class="cv-gallery-{{ section.id }} reveal">
  <div class="cv-gallery-inner">
    <div class="cv-header">
      <h2 class="cv-title">{{ section.settings.heading | default: 'Our Customer Review' }}</h2>
    </div>

    <div class="cv-grid">
      {%- for i in (1..5) -%}
        {%- assign video_key = 'video_' | append: i -%}
        {%- assign video = section.settings[video_key] -%}
        
        <div class="cv-item">
          {%- if video != blank -%}
            {{ video | video_tag: 
              autoplay: true, 
              loop: true, 
              muted: true, 
              playsinline: true, 
              controls: false,
              preload: "metadata"
            }}
          {%- else -%}
            <div style="height:100%; display:flex; align-items:center; justify-content:center; color:#444; font-size:12px; text-align:center; padding:20px;">
              Video {{ i }} Placeholder
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Video Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Customer Review"
    },
    { "type": "video", "id": "video_1", "label": "Customer Video 1" },
    { "type": "video", "id": "video_2", "label": "Customer Video 2" },
    { "type": "video", "id": "video_3", "label": "Customer Video 3" },
    { "type": "video", "id": "video_4", "label": "Customer Video 4" },
    { "type": "video", "id": "video_5", "label": "Customer Video 5" }
  ],
  "presets": [
    {
      "name": "Customer Video Gallery"
    }
  ]
}
{% endschema %}
