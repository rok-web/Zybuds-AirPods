<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {%- if template == 'product' -%}
      {{ product.title }} | {{ shop.name }}
    {%- elsif page_title -%}
      {{ page_title }} | {{ shop.name }}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>
  <meta name="description" content="{{ page_description | default: shop.description | escape }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Shopify required -->
  {{ content_for_header }}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'style.css' | asset_url | stylesheet_tag }}
</head>

<body>

  <!-- Notification Popup -->
  <div class="notif-popup" id="notifPopup">
    <div class="notif-dot"></div>
    🔥 <span id="notifText">23 people ordered today</span>
  </div>

  <!-- Header -->
  {% render 'header' %}

  <!-- Main content -->
  <main>
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {% render 'footer' %}

  <!-- Mobile sticky bar -->
  <div class="mob-bar">
    <div class="mob-price-wrap">
      <div class="mob-price-main">
        {%- if template == 'product' -%}
          {{ product.price | money }}
        {%- else -%}
          ₹1,400
        {%- endif -%}
      </div>
      <div class="mob-price-old">
        {%- if template == 'product' and product.compare_at_price > product.price -%}
          MRP {{ product.compare_at_price | money }}
        {%- else -%}
          MRP ₹3,499
        {%- endif -%}
      </div>
    </div>
    <button class="mob-order" onclick="handleOrder()">Pay ₹99 → Confirm</button>
  </div>

  <!-- WhatsApp floating button -->
  <a href="https://wa.me/91{{ settings.whatsapp_number | default: '0000000000' }}" class="wa-float-btn" target="_blank" rel="noopener">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12.031 6.172c-2.32 0-4.591.536-6.559 1.551l-.47.244-3.52-.924.94 3.434-.27.428A6.386 6.386 0 0 0 1.2 13.912c0 3.521 2.864 6.386 6.386 6.386 1.488 0 2.924-.511 4.073-1.442l.462-.375 3.551.931-.945-3.46.287-.457a6.368 6.368 0 0 0 .973-3.383c0-3.522-2.864-6.387-6.387-6.387h-.002zm5.424 9.12c-.223.63-.889 1.157-1.465 1.423-.42.193-.949.349-2.585-.316-2.09-.851-3.434-2.986-3.539-3.125-.105-.139-.854-1.134-.854-2.18s.554-1.56.751-1.77c.197-.21.43-.263.573-.263.143 0 .287.001.41.007.135.006.314-.051.493.381.185.445.632 1.538.687 1.648.055.111.092.24.018.388-.074.148-.111.24-.222.37-.111.13-.233.29-.333.388-.111.111-.227.232-.098.454.129.222.574.947 1.233 1.533.849.755 1.564 1.002 1.786 1.113.222.111.351.093.481-.055.13-.149.554-.648.702-.87.148-.223.296-.186.498-.111.204.074 1.295.611 1.517.722.222.111.37.167.425.26.056.093.056.537-.166 1.168z"/></svg>
  </a>

  <!-- Theme JS -->
  {{ 'script.js' | asset_url | script_tag }}
</body>
</html>
