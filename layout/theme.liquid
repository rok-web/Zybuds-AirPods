<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {%- if template == 'product' -%}
      {{ product.title }} — {{ settings.shop_name_override | default: shop.name }} | {{ settings.city | default: 'Hyderabad' }}
    {%- elsif page_title -%}
      {{ page_title }} | {{ settings.shop_name_override | default: shop.name }}
    {%- else -%}
      {{ settings.shop_name_override | default: shop.name }} — Premium Wireless Earbuds | {{ settings.city | default: 'Hyderabad' }}
    {%- endif -%}
  </title>
  <meta name="description" content="{{ page_description | default: shop.description | escape }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Shopify required -->
  {{ content_for_header }}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'zybuds-base.css' | asset_url | stylesheet_tag }}
</head>

<body>

  <!-- Notification Popup -->
  <div class="notif-popup" id="notifPopup">
    <div class="notif-dot"></div>
    🔥 <span id="notifText">23 people ordered today</span>
  </div>

  <!-- Header Section -->
  {% section 'header' %}

  <!-- Main content -->
  <main>
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {% render 'footer' %}

  <!-- Mobile sticky bar -->
  <div class="mob-bar" id="mobBar">
    <div class="mob-price-wrap">
      <div class="mob-price-main" id="mobPriceMain">
        {%- if template == 'product' -%}
          {{ product.price | money }}
        {%- else -%}
          ₹1,400
        {%- endif -%}
      </div>
      <div class="mob-price-old">
        {%- if template == 'product' and product.compare_at_price > product.price -%}
          MRP {{ product.compare_at_price | money }}
        {%- else -%}
          MRP ₹3,499
        {%- endif -%}
      </div>
    </div>
    <button class="mob-order" id="mobOrderBtn" onclick="handleOrder()">Pay ₹{{ settings.advance_amount | default: '99' }} → Confirm</button>
  </div>

  <!-- Floating Order Now button -->
  <button class="float-order-btn" onclick="handleOrder()" aria-label="Order Now">
    <span>Order Now</span>
  </button>

  <!-- Pass global settings to JS -->
  {%- assign popup_msg = settings.popup_message | default: '🔥 {orders} people ordered today|📦 7 orders delivered this morning|⚡ 3 people just viewed this product|✅ 500+ orders completed in Hyderabad' -%}
  <script>
    window.ZybudsSettings = {
      advanceAmount: {{ settings.advance_amount | default: 99 }},
      warrantyYears: {{ settings.warranty_years | default: 1 }},
      city: {{ settings.city | default: 'Hyderabad' | json }},
      founderName: {{ settings.founder_name | default: 'Mahesh' | json }},
      ordersDelivered: {{ settings.orders_delivered | default: '500+' | json }},
      popupMessages: {{ popup_msg | json }}
    };
  </script>

  <!-- Theme JS -->
  {{ 'zybuds-main.js' | asset_url | script_tag }}
</body>
</html>
