<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {%- if template == 'product' -%}
      {{ product.title }} — {{ settings.shop_name_override | default: shop.name }} | {{ settings.city | default: 'Hyderabad' }}
    {%- elsif page_title -%}
      {{ page_title }} | {{ settings.shop_name_override | default: shop.name }}
    {%- else -%}
      {{ settings.shop_name_override | default: shop.name }} — Premium Wireless Earbuds | {{ settings.city | default: 'Hyderabad' }}
    {%- endif -%}
  </title>
  <meta name="description" content="{{ page_description | default: shop.description | escape }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Shopify required -->
  {{ content_for_header }}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'zybuds-base.css' | asset_url | stylesheet_tag }}
</head>

<body>

  <!-- Notification Popup -->
  <div class="notif-popup" id="notifPopup">
    <div class="notif-dot"></div>
    🔥 <span id="notifText">23 people ordered today</span>
  </div>

  <!-- Header Section -->
  {% section 'header' %}

  <!-- Main content -->
  <main>
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {% render 'footer' %}

  <!-- Mobile sticky bar -->
  <div class="mob-bar" id="mobBar">
    <div class="mob-price-wrap">
      <div class="mob-price-main" id="mobPriceMain">
        {%- if template == 'product' -%}
          {{ product.price | money }}
        {%- else -%}
          ₹1,400
        {%- endif -%}
      </div>
      <div class="mob-price-old">
        {%- if template == 'product' and product.compare_at_price > product.price -%}
          MRP {{ product.compare_at_price | money }}
        {%- else -%}
          MRP ₹3,499
        {%- endif -%}
      </div>
    </div>
    <button class="mob-order" id="mobOrderBtn" onclick="handleOrder()">Pay ₹{{ settings.advance_amount | default: '99' }} → Confirm</button>
  </div>

  <!-- WhatsApp floating button -->
  <a href="https://wa.me/91{{ settings.whatsapp_number | default: '9100000000' }}" class="wa-float-btn" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>

  <!-- Pass global settings to JS -->
  <script>
    window.ZybudsSettings = {
      advanceAmount: {{ settings.advance_amount | default: 99 }},
      warrantyYears: {{ settings.warranty_years | default: 1 }},
      city: {{ settings.city | default: 'Hyderabad' | json }},
      founderName: {{ settings.founder_name | default: 'Mahesh' | json }},
      ordersDelivered: {{ settings.orders_delivered | default: '500+' | json }},
      whatsappNumber: {{ settings.whatsapp_number | default: '9100000000' | json }},
      popupMessages: {{ settings.popup_message | default: '🔥 {orders} people ordered today|📦 7 orders delivered this morning|⚡ 3 people just viewed this product|✅ 500+ orders completed in Hyderabad' | json }}
    };
  </script>

  <!-- Theme JS -->
  {{ 'zybuds-main.js' | asset_url | script_tag }}
</body>
</html>
